<!--
  清如 ClearSpring V2.0 - 服务页 (Stitch 风格)
  页面路径：pages/service/service
-->

<view class="service-page">
  <!-- 顶部导航栏 -->
  <view class="navbar glass-effect">
    <view class="navbar-content">
      <text class="navbar-title">服务</text>
    </view>
  </view>

  <!-- 服务分类 Tab -->
  <view class="category-tabs">
    <scroll-view scroll-x class="tabs-scroll" enable-flex>
      <view 
        class="tab-item {{currentCategory === index ? 'active' : ''}}" 
        wx:for="{{categories}}" 
        wx:key="id"
        bindtap="switchCategory"
        data-index="{{index}}"
      >
        <text>{{item.name}}</text>
        <view class="tab-indicator" wx:if="{{currentCategory === index}}"></view>
      </view>
    </scroll-view>
  </view>

  <!-- 服务列表 -->
  <scroll-view scroll-y class="service-list" style="height: calc(100vh - 100rpx - 120rpx - 100rpx);">
    <view class="service-grid">
      <view 
        class="service-card card-shadow" 
        wx:for="{{filteredServices}}" 
        wx:key="id"
        bindtap="showServiceDetail"
        data-service="{{item}}"
      >
        <view class="service-image-wrapper">
          <image class="service-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="service-tag" wx:if="{{item.tag}}">{{item.tag}}</view>
        </view>
        
        <view class="service-content">
          <view class="service-header">
            <text class="service-title">{{item.title}}</text>
            <view class="service-rating" wx:if="{{item.rating}}">
              <text class="cuIcon-cuIcon-starfill text-yellow"></text>
              <text class="rating-value">{{item.rating}}</text>
            </view>
          </view>
          
          <text class="service-desc text-cut">{{item.description}}</text>
          
          <view class="service-footer">
            <view class="service-price">
              <text class="price-symbol">¥</text>
              <text class="price-value">{{item.price}}</text>
            </view>
            <button class="service-action-btn">立即放生</button>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
