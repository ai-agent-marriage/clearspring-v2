/**
 * 清如 ClearSpring V2.0 - 服务页样式
 * 页面路径：pages/service/service
 */

/* ====================
   CSS 变量继承
   ==================== */
page {
  --bg-primary: #EFEEE9;
  --primary-gold: #D4B87B;
  --primary-gold-dark: #B89A5B;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --card-radius: 24rpx;
  --btn-min-height: 88rpx;
  --shadow-light: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  --shadow-medium: 0 8rpx 40rpx rgba(0, 0, 0, 0.12);
}

/* ====================
   页面基础样式
   ==================== */
.service-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: var(--bg-primary);
}

/* ====================
   顶部导航栏
   ==================== */
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  z-index: 1000;
  padding-top: var(--status-bar-height, 0);
}

.glass-effect {
  background: rgba(239, 238, 233, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.3);
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
}

.navbar-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
}

/* ====================
   服务分类 Tab
   ==================== */
.category-tabs {
  position: fixed;
  top: calc(100rpx + var(--status-bar-height, 0));
  left: 0;
  right: 0;
  height: 100rpx;
  background: #FFFFFF;
  z-index: 999;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.tabs-scroll {
  white-space: nowrap;
  height: 100rpx;
}

.tab-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
  height: 100rpx;
  font-size: 30rpx;
  color: var(--text-secondary);
  position: relative;
  transition: all 0.3s ease;
}

.tab-item text {
  font-weight: 500;
}

.tab-item.active {
  color: var(--primary-gold-dark);
  font-weight: bold;
}

.tab-indicator {
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: var(--primary-gold);
  border-radius: 3rpx;
}

/* ====================
   服务列表
   ==================== */
.service-list {
  margin-top: 200rpx;
  padding: 0 30rpx 120rpx;
  box-sizing: border-box;
}

.service-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 30rpx;
}

.service-card {
  background: #FFFFFF;
  border-radius: var(--card-radius);
  overflow: hidden;
  box-shadow: var(--shadow-light);
  transition: all 0.3s ease;
}

.service-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-medium);
}

.service-image-wrapper {
  position: relative;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
}

.service-image {
  width: 100%;
  height: 100%;
}

.service-tag {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  padding: 8rpx 20rpx;
  background: rgba(212, 184, 123, 0.9);
  color: #FFFFFF;
  font-size: 24rpx;
  border-radius: 20rpx;
}

.service-content {
  padding: 30rpx;
}

.service-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.service-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  flex: 1;
}

.service-rating {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.service-rating text:first-child {
  font-size: 28rpx;
}

.rating-value {
  font-size: 24rpx;
  color: var(--text-hint);
}

.service-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.service-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.service-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 28rpx;
  color: #E54D42;
  font-weight: bold;
  margin-right: 4rpx;
}

.price-value {
  font-size: 40rpx;
  color: #E54D42;
  font-weight: bold;
}

.price-unit {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-left: 8rpx;
}

.service-sales {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.sales-value {
  font-size: 28rpx;
  color: var(--text-hint);
  font-weight: bold;
}

.sales-label {
  font-size: 22rpx;
  color: var(--text-hint);
}

.service-actions {
  padding: 0 30rpx 30rpx;
}

.action-btn {
  width: 100%;
  min-height: var(--btn-min-height);
  min-width: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-gold) 0%, var(--primary-gold-dark) 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(212, 184, 123, 0.4);
  min-height: 88rpx;
}

.btn-primary:active {
  transform: scale(0.95);
}

/* ====================
   空状态
   ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-state text:first-child {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-hint);
}

/* ====================
   加载更多
   ==================== */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  font-size: 28rpx;
  color: var(--text-hint);
  gap: 16rpx;
}

.loading {
  animation: rotate 1s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ====================
   服务详情弹窗
   ==================== */
.service-detail-modal {
  width: 100%;
  border-radius: 30rpx 30rpx 0 0;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.close-btn {
  font-size: 44rpx;
  color: var(--text-hint);
  padding: 10rpx;
}

.modal-content {
  padding: 0;
}

.detail-image-wrapper {
  width: 100%;
  height: 400rpx;
  overflow: hidden;
}

.detail-image {
  width: 100%;
  height: 100%;
}

.detail-info {
  padding: 30rpx;
}

.detail-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.detail-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.detail-price {
  display: flex;
  align-items: baseline;
}

.detail-price .price-symbol {
  font-size: 32rpx;
  color: #E54D42;
  font-weight: bold;
}

.detail-price .price-value {
  font-size: 56rpx;
  color: #E54D42;
  font-weight: bold;
}

.detail-sales {
  font-size: 26rpx;
  color: var(--text-hint);
}

.detail-divider {
  height: 1rpx;
  background: #EEEEEE;
  margin: 30rpx 0;
}

.detail-section {
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.section-content {
  display: block;
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text-secondary);
  text-align: justify;
}

.notice-text {
  background: rgba(255, 173, 0, 0.1);
  padding: 20rpx;
  border-radius: 12rpx;
  border-left: 6rpx solid #FFAD00;
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.rule-item text:first-child {
  font-size: 32rpx;
  flex-shrink: 0;
}

/* ====================
   弹窗底部操作
   ==================== */
.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #EEEEEE;
}

.footer-btn {
  flex: 1;
  min-height: var(--btn-min-height);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
}

.btn-cancel {
  background: #F5F5F5;
  color: var(--text-secondary);
  min-height: 88rpx;
}

.btn-confirm {
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(229, 77, 66, 0.4);
  min-height: 88rpx;
}

/* ====================
   底部 TabBar
   ==================== */
.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(100rpx + env(safe-area-inset-bottom) / 2);
  padding-bottom: calc(env(safe-area-inset-bottom) / 2);
  background: #FFFFFF;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 1000;
}

.tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 20rpx;
  min-height: var(--btn-min-height);
  min-width: 88rpx;
  transition: all 0.3s ease;
}

.tabbar-item text:first-child {
  font-size: 44rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.tabbar-label {
  font-size: 22rpx;
  color: #999999;
}

.tabbar-item.active text:first-child,
.tabbar-item.active .tabbar-label {
  color: var(--primary-gold);
}

.tabbar-item:active {
  transform: scale(0.9);
}

/* ====================
   响应式适配
   ==================== */
@media (max-width: 375px) {
  .navbar-title {
    font-size: 32rpx;
  }
  
  .service-content {
    padding: 24rpx;
  }
  
  .service-title {
    font-size: 28rpx;
  }
  
  .price-value {
    font-size: 36rpx;
  }
}
