/* 清如 ClearSpring V2.0 - 服务页样式 (Stitch 风格) */

.service-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #EFEEE9 0%, #E8E6DF 100%);
}

/* 顶部导航栏 */
.navbar {
  height: 100rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.navbar-content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.navbar-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #4A5D4E;
}

/* 服务分类 Tab */
.category-tabs {
  height: 100rpx;
  padding: 0 24rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid rgba(74, 93, 78, 0.1);
}

.tabs-scroll {
  white-space: nowrap;
  flex: 1;
}

.tab-item {
  display: inline-block;
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  font-size: 28rpx;
  color: #666666;
  border-radius: 24rpx;
  background: rgba(74, 93, 78, 0.05);
  position: relative;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #D4B87B;
  background: linear-gradient(135deg, rgba(212, 184, 123, 0.2) 0%, rgba(212, 184, 123, 0.1) 100%);
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #D4B87B 0%, #C4A86B 100%);
  border-radius: 3rpx;
}

/* 服务列表 */
.service-list {
  flex: 1;
  padding: 24rpx;
}

.service-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.service-card {
  border-radius: 24rpx;
  background: #FFFFFF;
  overflow: hidden;
  transition: all 0.3s ease;
}

.service-card:active {
  transform: scale(0.98);
}

.service-image-wrapper {
  position: relative;
  height: 240rpx;
  overflow: hidden;
}

.service-image {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #4A5D4E 0%, #334537 100%);
}

.service-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 8rpx 16rpx;
  background: rgba(212, 184, 123, 0.9);
  color: #FFFFFF;
  font-size: 20rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.service-content {
  padding: 20rpx;
}

.service-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.service-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  flex: 1;
}

.service-rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.rating-value {
  font-size: 20rpx;
  color: #FFB800;
}

.service-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.service-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.service-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #D4B87B;
  margin-right: 4rpx;
}

.price-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #D4B87B;
}

.service-action-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #4A5D4E 0%, #334537 100%);
  color: #FFFFFF;
  font-size: 24rpx;
  border-radius: 20rpx;
  border: none;
  font-weight: 600;
}

.service-action-btn::after {
  border: none;
}

/* 卡片阴影 */
.card-shadow {
  box-shadow: 0 8rpx 24rpx rgba(74, 93, 78, 0.12);
}

/* 液态玻璃效果 */
.glass-effect {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}
