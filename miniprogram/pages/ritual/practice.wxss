/* pages/ritual/practice.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F5F0E6 0%, #FFFFFF 100%);
  padding: 0 30rpx;
  padding-bottom: 160rpx;
}

/* 头部 */
.header {
  padding: 40rpx 0 30rpx;
}

.phase-indicator {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.phase-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #999999;
  padding: 12rpx 0;
  background: #F5F5F5;
  border-radius: 24rpx;
}

.phase-item.active {
  background: linear-gradient(135deg, #D4A574 0%, #C89564 100%);
  color: #FFFFFF;
  font-weight: 500;
}

.phase-line {
  width: 40rpx;
  height: 4rpx;
  background: #E0E0E0;
  margin: 0 10rpx;
}

/* 阶段内容 */
.phase-content {
  padding-bottom: 40rpx;
}

/* 区块 */
.section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

/* 清单 */
.checklist {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.check-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.check-item.checked {
  background: linear-gradient(135deg, rgba(82, 196, 26, 0.1) 0%, rgba(56, 158, 13, 0.1) 100%);
  border: 2rpx solid #52C41A;
}

.check-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  color: #D4A574;
}

.check-item.checked .check-icon {
  color: #52C41A;
}

.check-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

/* 提示 */
.tips-section {
  background: linear-gradient(135deg, rgba(212, 165, 116, 0.1) 0%, rgba(200, 149, 100, 0.1) 100%);
  border: 2rpx dashed #D4A574;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

/* 表单 */
.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx 24rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

.form-unit {
  font-size: 26rpx;
  color: #999999;
  margin-left: 12rpx;
}

/* 计时器 */
.timer-box {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(24, 144, 255, 0.1) 0%, rgba(9, 109, 217, 0.1) 100%);
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.timer-label {
  font-size: 28rpx;
  color: #666666;
}

.timer-value {
  font-size: 28rpx;
  color: #1890FF;
  font-weight: 500;
}

/* 回向文 */
.dedication-box {
  padding: 30rpx;
  background: linear-gradient(135deg, rgba(212, 165, 116, 0.1) 0%, rgba(200, 149, 100, 0.1) 100%);
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #D4A574;
}

.dedication-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* 按钮 */
.btn {
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #D4A574 0%, #C89564 100%);
  color: #FFFFFF;
  width: 100%;
}

.btn-primary[disabled] {
  opacity: 0.5;
}

.btn-success {
  background: linear-gradient(135deg, #52C41A 0%, #389E0D 100%);
  color: #FFFFFF;
  width: 100%;
}

.btn-small {
  height: 64rpx;
  padding: 0 40rpx;
  background: linear-gradient(135deg, #D4A574 0%, #C89564 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  margin-top: 20rpx;
}

.btn-home {
  background: linear-gradient(135deg, #52C41A 0%, #389E0D 100%);
  color: #FFFFFF;
  width: 100%;
  margin-top: 30rpx;
}

/* 操作区 */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 30rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

/* 完成弹窗 */
.complete-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.complete-content {
  background: #FFFFFF;
  border-radius: 30rpx;
  padding: 80rpx 60rpx;
  text-align: center;
  width: 80%;
}

.complete-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.complete-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 20rpx;
}

.complete-desc {
  font-size: 28rpx;
  color: #666666;
  display: block;
  margin-bottom: 40rpx;
}

.merit-summary {
  display: flex;
  align-items: baseline;
  justify-content: center;
  background: linear-gradient(135deg, rgba(82, 196, 26, 0.1) 0%, rgba(56, 158, 13, 0.1) 100%);
  padding: 30rpx 60rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.merit-num {
  font-size: 72rpx;
  font-weight: bold;
  color: #52C41A;
  margin-right: 16rpx;
}

.merit-label {
  font-size: 28rpx;
  color: #666666;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  font-size: 28rpx;
  color: #999999;
}
