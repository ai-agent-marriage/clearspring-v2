/* 清如 ClearSpring V2.0 - 订单页样式 (Stitch 风格) */

.order-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #EFEEE9 0%, #E8E6DF 100%);
}

/* 顶部导航栏 */
.navbar {
  height: 100rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.navbar-content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.navbar-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #4A5D4E;
}

/* 滚动内容区 */
.content-scroll {
  flex: 1;
  padding: 24rpx;
}

/* 服务信息卡片 */
.service-info-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
}

.service-header {
  display: flex;
  gap: 24rpx;
}

.service-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #4A5D4E 0%, #334537 100%);
}

.service-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.service-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.service-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 28rpx;
  color: #D4B87B;
  margin-right: 4rpx;
}

.price-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #D4B87B;
}

/* 订单表单 */
.order-form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 表单区块 */
.form-section {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 12rpx;
}

.section-icon {
  font-size: 32rpx;
  color: #4A5D4E;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

/* 选择器 */
.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(74, 93, 78, 0.05);
  border-radius: 16rpx;
}

.picker-label {
  font-size: 28rpx;
  color: #333333;
}

.text-hint {
  font-size: 28rpx;
  color: #999999;
}

/* 数量选择器 */
.quantity-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 16rpx;
}

.quantity-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4A5D4E 0%, #334537 100%);
  color: #FFFFFF;
  font-size: 36rpx;
  border-radius: 50%;
}

.quantity-btn.disabled {
  opacity: 0.5;
}

.quantity-input {
  width: 120rpx;
  height: 72rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  background: rgba(74, 93, 78, 0.05);
  border-radius: 16rpx;
  border: 2rpx solid rgba(74, 93, 78, 0.1);
}

.quantity-unit {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}

/* 输入框 */
.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  background: rgba(74, 93, 78, 0.05);
  border-radius: 16rpx;
  border: 2rpx solid rgba(74, 93, 78, 0.1);
}

.input-error {
  border-color: #ff4d4f !important;
  background-color: #fff5f5 !important;
}

/* 文本域 */
.blessing-input {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
  background: rgba(74, 93, 78, 0.05);
  border-radius: 16rpx;
  border: 2rpx solid rgba(74, 93, 78, 0.1);
  line-height: 1.6;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 20rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 订单摘要 */
.order-summary {
  padding: 24rpx;
  background: linear-gradient(135deg, #4A5D4E 0%, #334537 100%);
  color: #FFFFFF;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.summary-row:last-child {
  border-bottom: none;
}

.summary-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.summary-value {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.summary-row.total {
  margin-top: 12rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.2);
  border-bottom: none;
}

.total-price {
  display: flex;
  align-items: baseline;
}

.total-price .price-symbol {
  font-size: 32rpx;
  color: #D4B87B;
}

.total-price .price-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #D4B87B;
}

/* 提交按钮 */
.submit-section {
  margin-top: 24rpx;
  margin-bottom: 40rpx;
}

.submit-btn {
  width: 100%;
  height: 120rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #4A5D4E 0%, #334537 100%);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  border: none;
}

.submit-btn::after {
  border: none;
}

/* 卡片阴影 */
.card-shadow {
  box-shadow: 0 8rpx 24rpx rgba(74, 93, 78, 0.12);
}

/* 液态玻璃效果 */
.glass-effect {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}
