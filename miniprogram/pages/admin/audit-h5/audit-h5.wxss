/**
 * 清如 ClearSpring V2.0 - 管理端资质审核 H5 页样式
 * 页面路径：pages/admin/audit-h5/audit-h5
 * 
 * 设计规范：
 * - 主色调：岱绿 #4A5D4E
 * - 组件圆角：24rpx
 * - 移动端优化
 */

/* ====================
   CSS 变量定义
   ==================== */
page {
  --executor-green: #4A5D4E;
  --executor-green-light: #6B7D6E;
  --executor-green-dark: #3A4A3E;
  --executor-green-bg: rgba(74, 93, 78, 0.08);
  --bg-primary: #F5F5F0;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --card-radius: 24rpx;
  --btn-min-height: 88rpx;
  --shadow-light: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  --shadow-medium: 0 8rpx 40rpx rgba(0, 0, 0, 0.12);
}

/* ====================
   页面基础样式
   ==================== */
.audit-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: var(--bg-primary);
  background-image: linear-gradient(135deg, #F5F5F0 0%, #EBEAE6 100%);
}

/* ====================
   筛选 Tab
   ==================== */
.filter-tabs {
  display: flex;
  background: #FFFFFF;
  padding: 20rpx 30rpx;
  box-shadow: var(--shadow-light);
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: var(--text-secondary);
  position: relative;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: var(--executor-green);
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(90deg, var(--executor-green) 0%, var(--executor-green-light) 100%);
  border-radius: 3rpx;
}

.tab-badge {
  margin-left: 12rpx;
  padding: 4rpx 16rpx;
  background: #F44336;
  color: #FFFFFF;
  font-size: 24rpx;
  border-radius: 20rpx;
}

/* ====================
   列表滚动区域
   ==================== */
.list-scroll {
  flex: 1;
  padding: 30rpx;
  box-sizing: border-box;
}

/* ====================
   审核卡片
   ==================== */
.audit-list {
  padding-bottom: 40rpx;
}

.audit-card {
  background: #FFFFFF;
  border-radius: var(--card-radius);
  box-shadow: var(--shadow-light);
  overflow: hidden;
  margin-bottom: 30rpx;
  transition: all 0.3s ease;
}

.audit-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-medium);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: var(--text-hint);
}

.status-tag {
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.status-tag.pending {
  background: rgba(255, 193, 7, 0.15);
  color: #FFC107;
}

.status-tag.approved {
  background: rgba(76, 175, 80, 0.15);
  color: #4CAF50;
}

.status-tag.rejected {
  background: rgba(244, 67, 54, 0.15);
  color: #F44336;
}

.card-body {
  padding: 30rpx;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  width: 160rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.completeness-bar {
  flex: 1;
  height: 12rpx;
  background: rgba(0, 0, 0, 0.1);
  border-radius: 6rpx;
  overflow: hidden;
  margin: 0 20rpx;
}

.completeness-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--executor-green) 0%, var(--executor-green-light) 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.completeness-text {
  width: 80rpx;
  text-align: right;
  font-size: 28rpx;
  color: var(--executor-green);
  font-weight: bold;
}

.preview-images {
  display: flex;
  gap: 12rpx;
}

.preview-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--card-radius);
  border: 2rpx solid var(--executor-green-bg);
}

.card-footer {
  padding: 30rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.action-btns {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  min-height: var(--btn-min-height);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  transition: all 0.3s ease;
}

.action-btn text:first-child {
  font-size: 32rpx;
}

.reject-btn {
  background: rgba(244, 67, 54, 0.1);
  color: #F44336;
}

.reject-btn:active {
  background: rgba(244, 67, 54, 0.2);
}

.approve-btn {
  background: linear-gradient(135deg, var(--executor-green) 0%, var(--executor-green-light) 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(74, 93, 78, 0.3);
}

.approve-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(74, 93, 78, 0.2);
}

.audit-time {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-hint);
}

/* ====================
   空状态
   ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-state text:first-child {
  font-size: 120rpx;
  color: rgba(0, 0, 0, 0.1);
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-hint);
}

/* ====================
   加载更多
   ==================== */
.load-more,
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: var(--text-hint);
  gap: 12rpx;
}

.load-more text:first-child {
  font-size: 32rpx;
  animation: rotate 1s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ====================
   审核弹窗
   ==================== */
.audit-modal .cu-dialog {
  width: 90%;
  max-height: 80vh;
  border-radius: var(--card-radius);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.close-icon {
  font-size: 40rpx;
  color: var(--text-hint);
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx;
}

.detail-section {
  margin-bottom: 40rpx;
}

.detail-section:last-child {
  margin-bottom: 0;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.detail-list {
  background: var(--executor-green-bg);
  border-radius: var(--card-radius);
  padding: 24rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.detail-row:first-child {
  padding-top: 0;
}

.detail-row:last-child {
  padding-bottom: 0;
}

.detail-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.detail-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.image-item {
  position: relative;
  border-radius: var(--card-radius);
  overflow: hidden;
  background: var(--executor-green-bg);
}

.image-item image {
  width: 100%;
  height: 240rpx;
}

.image-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #FFFFFF;
  font-size: 24rpx;
  text-align: center;
}

.reason-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.reason-tag {
  padding: 16rpx 28rpx;
  background: #FFFFFF;
  border: 2rpx solid rgba(74, 93, 78, 0.3);
  border-radius: 30rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all 0.3s ease;
}

.reason-tag:active {
  transform: scale(0.95);
}

.reason-tag.active {
  background: var(--executor-green);
  border-color: var(--executor-green);
  color: #FFFFFF;
}

.reason-input-wrap {
  background: #FFFFFF;
  border-radius: var(--card-radius);
  border: 2rpx solid rgba(0, 0, 0, 0.1);
  padding: 20rpx;
}

.reason-input {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.modal-btn {
  flex: 1;
  min-height: var(--btn-min-height);
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: none;
  transition: all 0.3s ease;
}

.modal-btn text:first-child {
  font-size: 32rpx;
}

.cancel-btn {
  background: rgba(0, 0, 0, 0.1);
  color: var(--text-secondary);
}

.cancel-btn:active {
  background: rgba(0, 0, 0, 0.2);
}

.confirm-btn.approve {
  background: linear-gradient(135deg, var(--executor-green) 0%, var(--executor-green-light) 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(74, 93, 78, 0.3);
}

.confirm-btn.reject {
  background: linear-gradient(135deg, #F44336 0%, #D32F2F 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(244, 67, 54, 0.3);
}

/* ====================
   响应式适配
   ==================== */
@media (max-width: 375px) {
  .filter-tabs {
    padding: 16rpx 20rpx;
  }
  
  .tab-item {
    font-size: 28rpx;
  }
  
  .audit-card {
    margin-bottom: 24rpx;
  }
  
  .card-header,
  .card-body,
  .card-footer {
    padding: 24rpx;
  }
  
  .user-name {
    font-size: 30rpx;
  }
  
  .action-btn {
    font-size: 28rpx;
    min-height: 80rpx;
  }
}
