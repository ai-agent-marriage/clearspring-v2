/* 清如 ClearSpring V2.0 - 登录页样式 (Stitch 风格) */

.login-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #EFEEE9 0%, #E8E6DF 100%);
  padding: 60rpx 32rpx;
}

/* Logo 区域 */
.logo-section {
  text-align: center;
  padding: 60rpx 0;
}

.logo-icon {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 32rpx;
  background: linear-gradient(135deg, #4A5D4E 0%, #334537 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(74, 93, 78, 0.2);
}

.logo-icon text {
  font-size: 80rpx;
  color: #D4B87B;
}

.logo-title {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #4A5D4E;
  margin-bottom: 12rpx;
}

.logo-subtitle {
  display: block;
  font-size: 28rpx;
  color: #999999;
}

/* 登录表单 */
.login-form {
  flex: 1;
  padding: 48rpx 32rpx;
  border-radius: 32rpx;
  background: #FFFFFF;
}

.form-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 48rpx;
  text-align: center;
}

.form-group {
  margin-bottom: 32rpx;
}

.input-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.input-label text:first-child {
  font-size: 32rpx;
  color: #4A5D4E;
}

.label-text {
  font-size: 28rpx;
  color: #666666;
  font-weight: 600;
}

.form-input {
  width: 100%;
  height: 100rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
  color: #333333;
  background: rgba(74, 93, 78, 0.05);
  border-radius: 24rpx;
  border: 2rpx solid rgba(74, 93, 78, 0.1);
}

.input-error {
  border-color: #ff4d4f !important;
  background-color: #fff5f5 !important;
}

.error-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #ff4d4f;
}

.code-input-wrapper {
  display: flex;
  gap: 16rpx;
}

.code-input {
  flex: 1;
  height: 100rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
  color: #333333;
  background: rgba(74, 93, 78, 0.05);
  border-radius: 24rpx;
  border: 2rpx solid rgba(74, 93, 78, 0.1);
}

.code-btn {
  width: 240rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #4A5D4E 0%, #334537 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 24rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.code-btn::after {
  border: none;
}

.code-btn.disabled {
  opacity: 0.6;
  background: #CCCCCC;
}

.login-btn {
  width: 100%;
  height: 120rpx;
  margin-top: 48rpx;
  background: linear-gradient(135deg, #4A5D4E 0%, #334537 100%);
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 600;
  border-radius: 32rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn::after {
  border: none;
}

.agreement {
  margin-top: 32rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  justify-content: center;
}

.agreement-text {
  font-size: 24rpx;
  color: #999999;
}

.agreement-link {
  font-size: 24rpx;
  color: #D4B87B;
  text-decoration: underline;
}

/* 底部说明 */
.footer {
  margin-top: 48rpx;
  text-align: center;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: #BBBBBB;
}

/* 卡片阴影 */
.card-shadow {
  box-shadow: 0 8rpx 24rpx rgba(74, 93, 78, 0.12);
}
