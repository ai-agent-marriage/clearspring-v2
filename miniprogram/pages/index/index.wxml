<!--
  清如 ClearSpring V2.0 - 祈福者端首页 (Stitch 风格重制版)
  页面路径：pages/index/index
  设计规范：
    - 背景色：宣纸底 #EFEEE9
    - 主色调：禅意金 #D4B87B
    - 辅助色：岱绿 #4A5D4E
    - 组件圆角：24rpx
    - 按钮热区：≥88rpx
    - 液态玻璃效果
-->

<view class="index-page">
  <!-- 顶部导航栏（无标题，更简洁） -->
  <view class="navbar glass-effect">
    <view class="navbar-content">
      <view class="navbar-actions">
        <view class="action-btn">
          <text class="cuIcon-cuIcon-notice"></text>
        </view>
        <view class="action-btn">
          <text class="cuIcon-cuIcon-settings"></text>
        </view>
      </view>
    </view>
  </view>

  <!-- 滚动内容区 -->
  <scroll-view scroll-y class="content-scroll" style="height: calc(100vh - 100rpx - 120rpx);">
    
    <!-- 欢迎语卡片（Stitch 风格） -->
    <view class="welcome-card card-shadow">
      <view class="welcome-header">
        <text class="welcome-greeting">早安，吉祥</text>
        <text class="welcome-subtitle">愿众生安乐，福慧双增</text>
      </view>
      <image class="welcome-image" src="/static/homepage/bird-hero.jpg" mode="aspectFill"></image>
    </view>

    <!-- 法师推荐语卡片 -->
    <view class="master-card card-shadow">
      <view class="card-header">
        <image class="master-avatar" src="/static/avatar/default.png" mode="aspectFill"></image>
        <view class="master-info">
          <text class="master-name">释清净法师</text>
          <text class="master-title">本寺住持 · 放生仪轨传承人</text>
        </view>
      </view>
      <view class="card-content">
        <text class="quote-text">"放生一事，乃如来一代时教之要旨，实众生离苦得乐之津梁。"</text>
      </view>
      <view class="card-footer">
        <text class="quote-source">—— 《放生仪轨》</text>
      </view>
    </view>

    <!-- 功德快捷入口 -->
    <view class="merit-grid">
      <view class="merit-item card-shadow" bindtap="goToTodayMerit">
        <view class="merit-icon">
          <text class="cuIcon-cuIcon-sun"></text>
        </view>
        <text class="merit-label">今日功德</text>
        <text class="merit-value">{{todayMeritCount}}</text>
      </view>
      <view class="merit-item card-shadow" bindtap="goToTotalMerit">
        <view class="merit-icon">
          <text class="cuIcon-cuIcon-rank"></text>
        </view>
        <text class="merit-label">累计功德</text>
        <text class="merit-value">{{totalMeritCount}}</text>
      </view>
      <view class="merit-item card-shadow" bindtap="goToMeritForest">
        <view class="merit-icon">
          <text class="cuIcon-cuIcon-tree"></text>
        </view>
        <text class="merit-label">功德林</text>
        <text class="merit-value">{{meritForestCount}}</text>
      </view>
    </view>

    <!-- 快速放生按钮 -->
    <view class="quick-release-section">
      <button class="quick-release-btn card-shadow" bindtap="quickRelease">
        <text class="cuIcon-cuIcon-fish"></text>
        <text class="btn-text">快速放生</text>
      </button>
    </view>

  </scroll-view>
</view>
