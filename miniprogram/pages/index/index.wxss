/* 清如 ClearSpring V2.0 - 首页样式 (Stitch 风格重制版) */

/* 页面容器 */
.index-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #EFEEE9 0%, #E8E6DF 100%);
}

/* 顶部导航栏 */
.navbar {
  height: 100rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex: 1;
}

.navbar-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
}

.action-btn text {
  font-size: 36rpx;
  color: #4A5D4E;
}

/* 滚动内容区 */
.content-scroll {
  padding: 24rpx;
}

/* 欢迎语卡片（Stitch 风格） */
.welcome-card {
  margin-bottom: 24rpx;
  padding: 48rpx 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #4A5D4E 0%, #334537 100%);
  color: #FFFFFF;
  overflow: hidden;
  position: relative;
}

.welcome-header {
  position: relative;
  z-index: 2;
}

.welcome-greeting {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: #D4B87B;
}

.welcome-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.welcome-image {
  position: absolute;
  top: 0;
  right: 0;
  width: 300rpx;
  height: 100%;
  opacity: 0.3;
  border-radius: 32rpx;
}

/* 法师卡片 */
.master-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: #FFFFFF;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.master-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 4rpx solid #D4B87B;
}

.master-info {
  flex: 1;
}

.master-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.master-title {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.card-content {
  margin-bottom: 24rpx;
}

.quote-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.8;
  color: #666666;
  font-style: italic;
  padding-left: 24rpx;
  border-left: 6rpx solid #D4B87B;
}

.card-footer {
  text-align: right;
}

.quote-source {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* 功德网格 */
.merit-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.merit-item {
  padding: 32rpx 16rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.merit-icon {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #D4B87B 0%, #C4A86B 100%);
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 40rpx;
}

.merit-label {
  font-size: 24rpx;
  color: #666666;
}

.merit-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #4A5D4E;
}

/* 快速放生按钮 */
.quick-release-section {
  margin-top: 24rpx;
}

.quick-release-btn {
  width: 100%;
  height: 120rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #4A5D4E 0%, #334537 100%);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 36rpx;
  font-weight: 600;
  border: none;
}

.quick-release-btn text {
  font-size: 40rpx;
  color: #D4B87B;
}

.btn-text {
  color: #FFFFFF !important;
}

/* 卡片阴影 */
.card-shadow {
  box-shadow: 0 8rpx 24rpx rgba(74, 93, 78, 0.12);
}

/* 液态玻璃效果 */
.glass-effect {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}
