/* pages/meditation/stats.wxss */
.stats-container {
  min-height: 100vh;
  background: #F5F1E8;
  padding: 20rpx;
}

/* 总览卡片 */
.overview-card {
  background: linear-gradient(135deg, #D4B87B 0%, #C4A86B 100%);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(212, 184, 123, 0.3);
}

.overview-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.overview-title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.overview-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.overview-stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.overview-item {
  text-align: center;
}

.overview-value {
  font-size: 56rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.overview-label {
  font-size: 24rpx;
  opacity: 0.9;
}

.overview-divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 通用区块 */
.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-subtitle {
  font-size: 26rpx;
  color: #999;
}

/* 日历网格 */
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
  margin-bottom: 30rpx;
}

.calendar-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  aspect-ratio: 1;
}

.day-date {
  font-size: 20rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.day-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  background: #F0F0F0;
}

.day-dot.level-0 {
  background: #F0F0F0;
}

.day-dot.level-1 {
  background: #C8E6C9;
}

.day-dot.level-2 {
  background: #81C784;
}

.day-dot.level-3 {
  background: #4CAF50;
}

.calendar-legend {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.legend-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 6rpx;
}

.legend-dot.level-0 {
  background: #F0F0F0;
}

.legend-dot.level-1 {
  background: #C8E6C9;
}

.legend-dot.level-2 {
  background: #81C784;
}

.legend-dot.level-3 {
  background: #4CAF50;
}

.legend-text {
  font-size: 22rpx;
  color: #999;
}

/* 徽章网格 */
.badges-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30rpx;
}

.badge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.badge-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 16rpx;
  background: #F8F6F0;
}

.badge-icon.unlocked {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  box-shadow: 0 8rpx 16rpx rgba(255, 215, 0, 0.3);
}

.badge-icon.locked {
  opacity: 0.4;
  filter: grayscale(100%);
}

.badge-name {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.badge-desc {
  font-size: 20rpx;
  color: #999;
  line-height: 1.4;
}

/* 周统计 */
.week-stats {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 300rpx;
  padding: 20rpx 0;
}

.week-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.week-day {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.week-bar-container {
  width: 40rpx;
  height: 200rpx;
  background: #F0F0F0;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
}

.week-bar {
  position: absolute;
  bottom: 0;
  width: 100%;
  background: linear-gradient(180deg, #D4B87B 0%, #C4A86B 100%);
  border-radius: 20rpx;
  transition: height 0.3s;
}

.week-value {
  font-size: 20rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 最爱课程 */
.favorite-course {
  display: flex;
  align-items: center;
  background: #F8F6F0;
  border-radius: 16rpx;
  padding: 20rpx;
}

.favorite-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.favorite-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.favorite-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.favorite-count {
  font-size: 24rpx;
  color: #D4B87B;
}

.empty-favorite {
  text-align: center;
  padding: 40rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
