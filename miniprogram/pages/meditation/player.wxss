/* pages/meditation/player.wxss */
.player-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #2C3E50 0%, #34495E 100%);
  padding: 40rpx;
  box-sizing: border-box;
}

/* 进度区域 */
.progress-section {
  margin-bottom: 40rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  color: #fff;
  font-size: 26rpx;
}

.progress-slider {
  width: 100%;
}

/* 引导区域 */
.guide-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.guide-circle {
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  position: relative;
}

.guide-circle.playing {
  animation: breathe 4s ease-in-out infinite;
}

@keyframes breathe {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

.guide-image {
  width: 100%;
  height: 100%;
}

.guide-text {
  text-align: center;
  color: #fff;
}

.guide-title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.guide-subtitle {
  font-size: 28rpx;
  opacity: 0.8;
  line-height: 1.6;
}

/* 倒计时区域 */
.countdown-section {
  margin-bottom: 40rpx;
}

.countdown-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  background: rgba(255, 255, 255, 0.1);
}

.countdown-time {
  font-size: 48rpx;
  font-weight: bold;
  color: #D4B87B;
  font-family: 'Courier New', monospace;
}

.countdown-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 10rpx;
}

/* 控制区域 */
.control-section {
  margin-bottom: 40rpx;
}

.play-controls {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 40rpx;
  gap: 60rpx;
}

.control-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}

.control-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.control-label {
  font-size: 22rpx;
  opacity: 0.7;
}

.main-btn {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D4B87B 0%, #C4A86B 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(212, 184, 123, 0.4);
}

.main-btn .control-icon {
  font-size: 60rpx;
  margin-bottom: 0;
}

.action-buttons {
  display: flex;
  justify-content: space-around;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
  opacity: 0.8;
}

.action-icon {
  font-size: 32rpx;
  margin-bottom: 10rpx;
}

.action-text {
  font-size: 24rpx;
}

/* 底部区域 */
.bottom-section {
  padding-bottom: 40rpx;
}

.complete-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #D4B87B 0%, #C4A86B 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.complete-btn[disabled] {
  background: #666;
  color: #999;
}
