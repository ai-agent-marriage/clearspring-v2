<!--
  清如 ClearSpring V2.0 - 收入管理
  页面路径：pages/executor/income/income
-->

<view class="income-page">
  <cu-custom bgColor="bg-gradual-green" :isBack="true">
    <block slot="content">收入管理</block>
  </cu-custom>

  <scroll-view scroll-y class="content-scroll">
    <!-- 收入统计卡片 -->
    <view class="income-card card-gradient">
      <view class="income-header">
        <text class="income-label">累计收入</text>
      </view>
      <view class="income-amount">
        <text class="currency">¥</text>
        <text class="number">{{totalIncome}}</text>
      </view>
      <view class="income-tabs">
        <view class="tab-item {{currentTab === 'today' ? 'active' : ''}}" bindtap="switchTab" data-tab="today">
          <text class="tab-value">¥{{todayIncome}}</text>
          <text class="tab-label">今日</text>
        </view>
        <view class="tab-item {{currentTab === 'week' ? 'active' : ''}}" bindtap="switchTab" data-tab="week">
          <text class="tab-value">¥{{weekIncome}}</text>
          <text class="tab-label">本周</text>
        </view>
        <view class="tab-item {{currentTab === 'month' ? 'active' : ''}}" bindtap="switchTab" data-tab="month">
          <text class="tab-value">¥{{monthIncome}}</text>
          <text class="tab-label">本月</text>
        </view>
      </view>
    </view>

    <!-- 提现入口 -->
    <view class="withdraw-section">
      <view class="withdraw-card card-shadow" bindtap="showWithdraw">
        <view class="withdraw-info">
          <text class="withdraw-label">可提现金额</text>
          <text class="withdraw-amount">¥{{availableAmount}}</text>
        </view>
        <view class="withdraw-action">
          <text class="withdraw-btn">提现</text>
          <text class="cuIcon-cuIcon-right"></text>
        </view>
      </view>
      <view class="withdraw-rules">
        <text class="cuIcon-cuIcon-info"></text>
        <text>满 100 元可提现，工作日 24 小时内到账</text>
      </view>
    </view>

    <!-- 收入明细 -->
    <view class="detail-section">
      <view class="section-title">
        <text class="cuIcon-cuIcon-list"></text>
        <text>收入明细</text>
      </view>

      <view wx:for="{{incomeList}}" wx:key="id" class="detail-item card-shadow">
        <view class="detail-left">
          <view class="detail-icon">
            <text class="cuIcon-cuIcon-task"></text>
          </view>
          <view class="detail-info">
            <text class="detail-title">{{item.taskName}}</text>
            <text class="detail-time">{{item.time}}</text>
          </view>
        </view>
        <view class="detail-right">
          <text class="detail-amount {{item.status === 'completed' ? 'positive' : ''}}">+¥{{item.amount}}</text>
          <text class="detail-status">{{item.statusText}}</text>
        </view>
      </view>

      <view wx:if="{{incomeList.length === 0}}" class="empty-state">
        <text class="cuIcon-cuIcon-empty"></text>
        <text class="empty-text">暂无收入记录</text>
      </view>

      <view wx:if="{{loading}}" class="loading-state">
        <text>加载中...</text>
      </view>
    </view>

    <view style="height: 100rpx;"></view>
  </scroll-view>
</view>
