/**
 * 清如 ClearSpring V2.0 - 任务助手样式
 */

page {
  --executor-green: #4A5D4E;
  --executor-green-light: #6B7D6E;
  --bg-primary: #F5F5F0;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --card-radius: 24rpx;
}

.assistant-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--bg-primary);
}

.content-scroll {
  flex: 1;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.card-shadow {
  background: #FFFFFF;
  border-radius: var(--card-radius);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 30rpx;
}

.task-detail {
  margin-top: 30rpx;
  padding: 30rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.status-tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: rgba(74, 93, 78, 0.15);
  color: var(--executor-green);
}

.detail-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
}

.detail-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.detail-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 30rpx;
}

.section-title text:first-child {
  margin-right: 16rpx;
  font-size: 40rpx;
  color: var(--executor-green);
}

.guide-steps {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.guide-step {
  display: flex;
  padding: 30rpx;
  position: relative;
}

.step-number {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--executor-green);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.step-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.step-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
}

.tip-item text:first-child {
  font-size: 36rpx;
  color: var(--executor-green);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.action-section {
  margin-top: 60rpx;
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  width: 100%;
  min-height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, var(--executor-green) 0%, var(--executor-green-light) 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(74, 93, 78, 0.4);
}

.action-btn.secondary {
  background: #FFFFFF;
  color: var(--executor-green);
  border: 2rpx solid var(--executor-green);
}

.action-btn:active {
  transform: scale(0.95);
}

.action-btn text:first-child {
  font-size: 36rpx;
}
