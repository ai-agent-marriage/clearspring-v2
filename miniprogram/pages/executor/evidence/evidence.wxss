/**
 * 清如 ClearSpring V2.0 - 证据提交样式
 */

page {
  --executor-green: #4A5D4E;
  --executor-green-light: #6B7D6E;
  --bg-primary: #F5F5F0;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --card-radius: 24rpx;
}

.evidence-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--bg-primary);
}

.content-scroll {
  flex: 1;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.card-shadow {
  background: #FFFFFF;
  border-radius: var(--card-radius);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 30rpx;
}

.task-info {
  margin-top: 30rpx;
  padding: 30rpx;
  display: flex;
}

.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-right: 16rpx;
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.section-title text:first-child {
  margin-right: 16rpx;
  font-size: 40rpx;
  color: var(--executor-green);
}

.required-mark {
  color: #F44336;
  margin-left: 8rpx;
}

.media-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.media-item {
  width: 100%;
  height: 300rpx;
  border-radius: var(--card-radius);
  overflow: hidden;
  position: relative;
}

.media-item image, .media-item video {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-btn text {
  font-size: 28rpx;
  color: #FFFFFF;
}

.upload-btn {
  width: 100%;
  height: 300rpx;
  border-radius: var(--card-radius);
  border: 2rpx dashed var(--executor-green);
  background: rgba(74, 93, 78, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-btn text:first-child {
  font-size: 64rpx;
  color: var(--executor-green);
  margin-bottom: 16rpx;
}

.upload-btn text:last-child {
  font-size: 26rpx;
  color: var(--text-hint);
}

.desc-section {
  margin-bottom: 40rpx;
}

.desc-input {
  width: 100%;
  min-height: 300rpx;
  padding: 30rpx;
  background: #FFFFFF;
  border-radius: var(--card-radius);
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 12rpx;
}

.location-section {
  margin-bottom: 60rpx;
}

.location-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
}

.location-text {
  font-size: 28rpx;
  color: var(--text-primary);
}

.location-card text:last-child {
  font-size: 32rpx;
  color: var(--text-hint);
}

.submit-section {
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.submit-btn {
  width: 100%;
  min-height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--executor-green) 0%, var(--executor-green-light) 100%);
  box-shadow: 0 8rpx 24rpx rgba(74, 93, 78, 0.4);
  border: none;
}

.submit-btn:active {
  transform: scale(0.95);
}

.submit-btn.disabled {
  background: rgba(0, 0, 0, 0.2);
  box-shadow: none;
}

.submit-btn text:first-child {
  font-size: 36rpx;
}

.submit-hint {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: var(--text-hint);
}
