/**
 * 清如 ClearSpring V2.0 - 执行者首页样式
 * 页面路径：pages/executor/home/home
 * 
 * 设计规范：
 * - 主色调：岱绿 #4A5D4E
 * - 组件圆角：24rpx
 * - 按钮热区：≥88rpx
 */

page {
  --executor-green: #4A5D4E;
  --executor-green-light: #6B7D6E;
  --executor-green-dark: #3A4A3E;
  --executor-green-bg: rgba(74, 93, 78, 0.08);
  --bg-primary: #F5F5F0;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --card-radius: 24rpx;
  --btn-min-height: 88rpx;
  --shadow-light: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  --shadow-medium: 0 8rpx 40rpx rgba(0, 0, 0, 0.12);
}

.home-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: var(--bg-primary);
  background-image: linear-gradient(135deg, #F5F5F0 0%, #EBEAE6 100%);
}

.content-scroll {
  flex: 1;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.card-shadow {
  background: #FFFFFF;
  border-radius: var(--card-radius);
  box-shadow: var(--shadow-light);
  overflow: hidden;
  margin-bottom: 30rpx;
}

.card-gradient {
  background: linear-gradient(135deg, var(--executor-green) 0%, var(--executor-green-light) 100%);
  border-radius: var(--card-radius);
  box-shadow: 0 8rpx 40rpx rgba(74, 93, 78, 0.3);
  overflow: hidden;
  margin-bottom: 30rpx;
}

/* 收入概览卡片 */
.income-card {
  margin-top: 30rpx;
  padding: 40rpx;
  color: #FFFFFF;
}

.income-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.income-label {
  font-size: 28rpx;
  opacity: 0.9;
}

.income-update {
  font-size: 22rpx;
  opacity: 0.7;
}

.income-amount {
  display: flex;
  align-items: baseline;
  margin-bottom: 40rpx;
}

.income-amount .currency {
  font-size: 40rpx;
  font-weight: bold;
  margin-right: 8rpx;
}

.income-amount .number {
  font-size: 72rpx;
  font-weight: bold;
}

.income-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 30rpx 0;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.8;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

.income-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  min-height: var(--btn-min-height);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  transition: all 0.3s ease;
  border: none;
}

.action-btn.primary {
  background: #FFFFFF;
  color: var(--executor-green);
}

.action-btn.secondary {
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.action-btn:active {
  transform: scale(0.95);
}

.action-btn text:first-child {
  font-size: 32rpx;
}

/* 任务统计卡片 */
.task-stats-card {
  padding: 30rpx;
}

.stats-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 30rpx;
}

.stats-title text:first-child {
  margin-right: 16rpx;
  font-size: 40rpx;
  color: var(--executor-green);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: var(--executor-green-bg);
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.stat-card:active {
  transform: scale(0.95);
  background: rgba(74, 93, 78, 0.15);
}

.stat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.stat-icon text {
  font-size: 40rpx;
  color: #FFFFFF;
}

.stat-number {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.stat-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 快捷操作入口 */
.quick-actions {
  margin-top: 40rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 30rpx;
}

.section-title text:first-child {
  margin-right: 16rpx;
  font-size: 40rpx;
  color: var(--executor-green);
}

.actions-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
}

.action-item:active {
  transform: scale(0.9);
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.action-icon text {
  font-size: 48rpx;
  color: #FFFFFF;
}

.action-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
}

/* 公告通知 */
.notice-section {
  margin-top: 40rpx;
}

.notice-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  transition: all 0.3s ease;
}

.notice-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-medium);
}

.notice-content {
  flex: 1;
}

.notice-text {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

.notice-card text:last-child {
  font-size: 32rpx;
  color: var(--text-hint);
}

/* 底部 TabBar */
.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(100rpx + env(safe-area-inset-bottom) / 2);
  padding-bottom: calc(env(safe-area-inset-bottom) / 2);
  background: #FFFFFF;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 1000;
}

.tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 20rpx;
  min-height: var(--btn-min-height);
  min-width: 88rpx;
  transition: all 0.3s ease;
}

.tabbar-item text:first-child {
  font-size: 44rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.tabbar-label {
  font-size: 22rpx;
  color: #999999;
}

.tabbar-item.active text:first-child,
.tabbar-item.active .tabbar-label {
  color: var(--executor-green);
}

.tabbar-item:active {
  transform: scale(0.9);
}

/* 通知按钮 */
.notification-btn {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.notification-btn text {
  font-size: 40rpx;
  color: #FFFFFF;
}

.notice-dot {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 16rpx;
  height: 16rpx;
  background: #F44336;
  border-radius: 50%;
  border: 2rpx solid #FFFFFF;
}
