.executor-home-page { min-height: 100vh; background: #EFEEE9; padding: 24rpx; }
.navbar { height: 100rpx; display: flex; align-items: center; justify-content: center; margin-bottom: 24rpx; }
.navbar-title { font-size: 36rpx; font-weight: 600; color: #4A5D4E; }
.stats-card { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; padding: 24rpx; border-radius: 24rpx; background: linear-gradient(135deg, #4A5D4E 0%, #334537 100%); color: #FFFFFF; margin-bottom: 24rpx; }
.stat-item { text-align: center; }
.stat-value { display: block; font-size: 36rpx; font-weight: 700; color: #D4B87B; margin-bottom: 8rpx; }
.stat-label { display: block; font-size: 24rpx; color: rgba(255,255,255,0.8); }
.section-title { font-size: 32rpx; font-weight: 600; color: #333333; margin: 24rpx 0 16rpx; }
.task-list { display: flex; flex-direction: column; gap: 16rpx; }
.task-card { padding: 24rpx; border-radius: 24rpx; background: #FFFFFF; }
.task-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.task-title { font-size: 28rpx; font-weight: 600; color: #333333; }
.task-price { font-size: 32rpx; font-weight: 700; color: #D4B87B; }
.task-info { display: flex; flex-direction: column; gap: 8rpx; margin-bottom: 16rpx; }
.task-location, .task-time { font-size: 24rpx; color: #666666; }
.task-btn { width: 100%; height: 88rpx; background: linear-gradient(135deg, #4A5D4E 0%, #334537 100%); color: #FFFFFF; font-size: 28rpx; border-radius: 24rpx; border: none; }
.card-shadow { box-shadow: 0 8rpx 24rpx rgba(74,93,78,0.12); }
