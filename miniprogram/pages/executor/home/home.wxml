<!-- 清如 ClearSpring V2.0 - 执行者首页 -->
<view class="executor-home-page">
  <view class="navbar">
    <text class="navbar-title">执行者首页</text>
  </view>
  
  <view class="stats-card card-shadow">
    <view class="stat-item">
      <text class="stat-value">{{totalOrders}}</text>
      <text class="stat-label">总订单</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{completedOrders}}</text>
      <text class="stat-label">已完成</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{totalIncome}}</text>
      <text class="stat-label">总收入</text>
    </view>
  </view>

  <view class="section-title">待执行任务</view>
  <view class="task-list">
    <view class="task-card card-shadow" wx:for="{{tasks}}" wx:key="id">
      <view class="task-header">
        <text class="task-title">{{item.title}}</text>
        <text class="task-price">¥{{item.price}}</text>
      </view>
      <view class="task-info">
        <text class="task-location">📍 {{item.location}}</text>
        <text class="task-time">⏰ {{item.time}}</text>
      </view>
      <button class="task-btn" bindtap="acceptTask" data-id="{{item.id}}">接受任务</button>
    </view>
  </view>
</view>
