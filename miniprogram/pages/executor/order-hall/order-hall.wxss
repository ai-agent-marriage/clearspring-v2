/**
 * 清如 ClearSpring V2.0 - 抢单大厅样式
 */

page {
  --executor-green: #4A5D4E;
  --executor-green-light: #6B7D6E;
  --bg-primary: #F5F5F0;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --card-radius: 24rpx;
  --btn-min-height: 88rpx;
}

.order-hall-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-primary);
}

.filter-section {
  padding: 20rpx 30rpx;
  background: #FFFFFF;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-item {
  display: inline-block;
  padding: 12rpx 30rpx;
  margin-right: 20rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 30rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all 0.3s ease;
}

.filter-item.active {
  background: var(--executor-green);
  color: #FFFFFF;
}

.order-list {
  flex: 1;
  padding: 0 30rpx 120rpx;
}

.order-card {
  margin-top: 20rpx;
  padding: 30rpx;
  background: #FFFFFF;
  border-radius: var(--card-radius);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-species {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--executor-green);
}

.order-species text:first-child {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.order-urgent text {
  padding: 6rpx 16rpx;
  background: #F44336;
  color: #FFFFFF;
  font-size: 24rpx;
  border-radius: 20rpx;
  opacity: 0;
}

.order-urgent.active text {
  opacity: 1;
}

.order-body {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.order-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-item {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.order-reward {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.reward-label {
  font-size: 24rpx;
  color: var(--text-hint);
}

.reward-amount {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF9800;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.08);
}

.order-distance {
  font-size: 24rpx;
  color: var(--text-hint);
}

.grab-btn {
  min-height: 88rpx;
  padding: 0 40rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, var(--executor-green) 0%, var(--executor-green-light) 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(74, 93, 78, 0.3);
}

.grab-btn:active {
  transform: scale(0.95);
}

.grab-btn.grabbed {
  background: rgba(0, 0, 0, 0.2);
  box-shadow: none;
}

.empty-state, .loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-state text:first-child {
  font-size: 120rpx;
  color: rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(100rpx + env(safe-area-inset-bottom) / 2);
  padding-bottom: calc(env(safe-area-inset-bottom) / 2);
  background: #FFFFFF;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 1000;
}

.tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 20rpx;
}

.tabbar-item text:first-child {
  font-size: 44rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.tabbar-label {
  font-size: 22rpx;
  color: #999999;
}

.tabbar-item.active text:first-child,
.tabbar-item.active .tabbar-label {
  color: var(--executor-green);
}
