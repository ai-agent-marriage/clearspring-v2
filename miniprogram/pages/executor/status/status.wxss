/**
 * 清如 ClearSpring V2.0 - 执行者端审核状态页样式
 * 页面路径：pages/executor/status/status
 * 
 * 设计规范：
 * - 主色调：岱绿 #4A5D4E
 * - 组件圆角：24rpx
 * - 按钮热区：≥88rpx
 */

/* ====================
   CSS 变量定义
   ==================== */
page {
  --executor-green: #4A5D4E;
  --executor-green-light: #6B7D6E;
  --executor-green-dark: #3A4A3E;
  --executor-green-bg: rgba(74, 93, 78, 0.08);
  --bg-primary: #F5F5F0;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --card-radius: 24rpx;
  --btn-min-height: 88rpx;
  --shadow-light: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  --shadow-medium: 0 8rpx 40rpx rgba(0, 0, 0, 0.12);
}

/* ====================
   页面基础样式
   ==================== */
.status-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: var(--bg-primary);
  background-image: linear-gradient(135deg, #F5F5F0 0%, #EBEAE6 100%);
}

.content-scroll {
  flex: 1;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.card-shadow {
  background: #FFFFFF;
  border-radius: var(--card-radius);
  box-shadow: var(--shadow-light);
  overflow: hidden;
  margin-bottom: 30rpx;
}

/* ====================
   审核结果卡片
   ==================== */
.result-card {
  margin-top: 30rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  transition: all 0.3s ease;
}

.result-card.pending {
  border-top: 6rpx solid #FFC107;
}

.result-card.auditing {
  border-top: 6rpx solid var(--executor-green);
}

.result-card.approved {
  border-top: 6rpx solid #4CAF50;
  background: linear-gradient(135deg, #FFFFFF 0%, #F1F8E9 100%);
}

.result-card.rejected {
  border-top: 6rpx solid #F44336;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFEBEE 100%);
}

.result-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.result-card.pending .result-icon {
  background: rgba(255, 193, 7, 0.15);
}

.result-card.pending .result-icon text {
  font-size: 64rpx;
  color: #FFC107;
}

.result-card.auditing .result-icon {
  background: var(--executor-green-bg);
}

.result-card.auditing .result-icon text {
  font-size: 64rpx;
  color: var(--executor-green);
}

.result-card.approved .result-icon {
  background: rgba(76, 175, 80, 0.15);
}

.result-card.approved .result-icon text {
  font-size: 64rpx;
  color: #4CAF50;
}

.result-card.rejected .result-icon {
  background: rgba(244, 67, 54, 0.15);
}

.result-card.rejected .result-icon text {
  font-size: 64rpx;
  color: #F44336;
}

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.result-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.result-time {
  font-size: 24rpx;
  color: var(--text-hint);
  padding: 12rpx 24rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 30rpx;
}

/* ====================
   驳回原因区域
   ==================== */
.reject-section {
  margin-top: 40rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 30rpx;
}

.section-title text:first-child {
  margin-right: 16rpx;
  font-size: 40rpx;
  color: var(--executor-green);
}

.reject-card {
  padding: 30rpx;
}

.reject-content {
  padding: 24rpx;
  background: rgba(244, 67, 54, 0.08);
  border-radius: 16rpx;
  border-left: 6rpx solid #F44336;
  margin-bottom: 30rpx;
}

.reject-content text {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text-primary);
}

.reject-suggestions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.suggestion-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.suggestion-item text:first-child {
  font-size: 32rpx;
  color: var(--executor-green);
  margin-right: 16rpx;
}

/* ====================
   成功引导区域
   ==================== */
.success-section {
  margin-top: 40rpx;
}

.guide-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.guide-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  transition: all 0.3s ease;
}

.guide-item:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-medium);
}

.guide-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.guide-icon text {
  font-size: 40rpx;
  color: #FFFFFF;
}

.guide-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.guide-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.guide-desc {
  font-size: 24rpx;
  color: var(--text-hint);
}

.guide-item text:last-child {
  font-size: 32rpx;
  color: var(--text-hint);
}

/* ====================
   待审核提示
   ==================== */
.pending-section {
  margin-top: 40rpx;
}

.pending-card {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.pending-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 193, 7, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.pending-icon text {
  font-size: 48rpx;
  color: #FFC107;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

.pending-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.pending-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 30rpx;
  line-height: 1.6;
}

.pending-tips {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 16rpx 20rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 16rpx;
}

.tip-item text:first-child {
  font-size: 32rpx;
  color: var(--executor-green);
  margin-right: 16rpx;
}

/* ====================
   重新提交按钮
   ==================== */
.resubmit-section {
  margin-top: 60rpx;
  margin-bottom: 40rpx;
}

.resubmit-btn {
  width: 100%;
  min-height: var(--btn-min-height);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--executor-green) 0%, var(--executor-green-light) 100%);
  box-shadow: 0 8rpx 24rpx rgba(74, 93, 78, 0.4);
  transition: all 0.3s ease;
  border: none;
}

.resubmit-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(74, 93, 78, 0.3);
}

.resubmit-btn text:first-child {
  font-size: 36rpx;
}

/* ====================
   响应式适配
   ==================== */
@media (max-width: 375px) {
  .result-card {
    padding: 40rpx 30rpx;
  }
  
  .result-title {
    font-size: 36rpx;
  }
  
  .guide-icon {
    width: 70rpx;
    height: 70rpx;
  }
}
