<!--
  清如 ClearSpring V2.0 - 原生拍摄
  页面路径：pages/executor/camera/camera
-->

<view class="camera-page">
  <view class="camera-preview">
    <camera wx:if="{{!hasPermission}}" device-position="back" flash="off" binderror="onCameraError" style="width: 100%; height: 100%;"></camera>
    <view wx:else class="permission-denied">
      <text class="cuIcon-cuIcon-camera"></text>
      <text>请允许使用相机权限</text>
      <button bindtap="requestPermission">去授权</button>
    </view>
  </view>

  <view class="watermark-overlay">
    <view class="watermark-text">{{watermarkText}}</view>
  </view>

  <view class="camera-controls">
    <view class="control-btn" bindtap="switchCamera">
      <text class="cuIcon-cuIcon-refresh"></text>
    </view>
    <view class="shutter-btn" bindtap="takePhoto"></view>
    <view class="control-btn" bindtap="toggleFlash">
      <text class="cuIcon-cuIcon-light"></text>
    </view>
  </view>

  <view class="photo-preview" wx:if="{{photoPath}}" bindtap="confirmPhoto">
    <image src="{{photoPath}}" mode="aspectFill"></image>
    <view class="preview-actions">
      <button class="action-btn retake" bindtap="retake">重拍</button>
      <button class="action-btn confirm" bindtap="confirmPhoto">使用这张</button>
    </view>
  </view>
</view>
