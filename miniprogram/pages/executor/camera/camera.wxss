/**
 * 清如 ClearSpring V2.0 - 原生拍摄样式
 */

page {
  --executor-green: #4A5D4E;
}

.camera-page {
  position: relative;
  width: 100%;
  height: 100vh;
  background: #000000;
}

.camera-preview {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.permission-denied {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.8);
  color: #FFFFFF;
}

.permission-denied text:first-child {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.permission-denied text:last-child {
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

.permission-denied button {
  background: var(--executor-green);
  color: #FFFFFF;
  border: none;
  border-radius: 44rpx;
  padding: 0 60rpx;
  min-height: 88rpx;
  font-size: 32rpx;
}

.watermark-overlay {
  position: absolute;
  bottom: 200rpx;
  left: 0;
  right: 0;
  padding: 0 40rpx;
  pointer-events: none;
}

.watermark-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
  line-height: 1.6;
}

.camera-controls {
  position: absolute;
  bottom: 60rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 0 60rpx;
  box-sizing: border-box;
}

.control-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.control-btn text {
  font-size: 40rpx;
  color: #FFFFFF;
}

.shutter-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #FFFFFF;
  border: 8rpx solid rgba(255, 255, 255, 0.5);
  box-sizing: border-box;
}

.shutter-btn:active {
  transform: scale(0.9);
}

.photo-preview {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #000000;
  z-index: 100;
}

.photo-preview image {
  width: 100%;
  height: 100%;
}

.preview-actions {
  position: absolute;
  bottom: 60rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  padding: 0 60rpx;
}

.preview-actions button {
  min-width: 200rpx;
  min-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
}

.preview-actions .retake {
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
}

.preview-actions .confirm {
  background: var(--executor-green);
  color: #FFFFFF;
}
