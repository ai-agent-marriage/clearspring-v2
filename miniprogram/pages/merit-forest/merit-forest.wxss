/* 清如 ClearSpring V2.0 - 功德林页样式 (Stitch 风格) */

.merit-forest-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #EFEEE9 0%, #E8E6DF 100%);
}

/* 顶部导航栏 */
.navbar {
  height: 100rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.navbar-content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.navbar-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #4A5D4E;
}

/* 统计卡片 */
.stats-card {
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #4A5D4E 0%, #334537 100%);
  color: #FFFFFF;
}

.stats-header {
  margin-bottom: 24rpx;
}

.stats-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  color: #D4B87B;
}

.stats-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.stat-item {
  text-align: center;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #D4B87B;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 功德证书墙 */
.certificate-wall {
  flex: 1;
  padding: 24rpx;
}

.wall-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.waterfall {
  column-count: 2;
  column-gap: 16rpx;
}

.certificate-card {
  break-inside: avoid;
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
}

.cert-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.cert-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  flex: 1;
}

.cert-date {
  font-size: 20rpx;
  color: #999999;
}

.cert-content {
  margin-bottom: 16rpx;
}

.cert-text {
  display: block;
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

.cert-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cert-merit {
  font-size: 28rpx;
  font-weight: 700;
  color: #D4B87B;
}

.cert-icon {
  font-size: 32rpx;
  color: #D4B87B;
}

/* 卡片阴影 */
.card-shadow {
  box-shadow: 0 8rpx 24rpx rgba(74, 93, 78, 0.12);
}

/* 液态玻璃效果 */
.glass-effect {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}
