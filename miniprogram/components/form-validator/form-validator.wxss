/* 表单验证组件样式 */

.form-validator-container {
  position: relative;
  width: 100%;
}

/* 错误提示消息 */
.error-message {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  margin-bottom: 12rpx;
  background: linear-gradient(135deg, #fff5f5 0%, #ffe8e8 100%);
  border-left: 4rpx solid #ff4d4f;
  border-radius: 8rpx;
  opacity: 0;
  transform: translateY(-10rpx);
  transition: all 0.3s ease;
}

.error-message.show {
  opacity: 1;
  transform: translateY(0);
  animation: fadeIn 0.3s ease forwards;
}

.error-message.hide {
  opacity: 0;
  transform: translateY(-10rpx);
  animation: fadeOut 0.3s ease forwards;
}

.error-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
}

.error-text {
  font-size: 12rpx;
  color: #ff4d4f;
  line-height: 1.5;
  flex: 1;
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeOut {
  from {
    opacity: 1;
    transform: translateY(0);
  }
  to {
    opacity: 0;
    transform: translateY(-10rpx);
  }
}

/* 输入框错误状态（通过父组件添加） */
.input-error {
  border-color: #ff4d4f !important;
  background-color: #fff5f5 !important;
}
