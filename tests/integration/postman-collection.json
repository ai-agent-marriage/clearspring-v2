              "path": ["api", "admin", "executors"],
              "query": [
                {"key": "status", "value": "active"},
                {"key": "page", "value": "1"},
                {"key": "pageSize", "value": "10"}
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET /api/admin/executors - 关键词搜索",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admin/executors?keyword=张&page=1&pageSize=10",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "executors"],
              "query": [
                {"key": "keyword", "value": "张"},
                {"key": "page", "value": "1"},
                {"key": "pageSize", "value": "10"}
              ]
            }
          },
          "response": []
        },
        {
          "name": "PUT /api/admin/executor/:id/status - 更新状态",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"inactive\",\n  \"remark\": \"暂时停用\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/executor/:id/status",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "executor", ":id", "status"],
              "variable": [
                {"key": "id", "value": "EXECUTOR_ID_HERE"}
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "分账配置",
      "item": [
        {
          "name": "GET /api/admin/profit-sharing - 获取配置",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admin/profit-sharing",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "profit-sharing"]
            }
          },
          "response": []
        },
        {
          "name": "PUT /api/admin/profit-sharing - 更新配置",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"platformRate\": 0.10,\n  \"executorMinRate\": 0.70,\n  \"executorMaxRate\": 0.90,\n  \"defaultExecutorRate\": 0.80,\n  \"minOrderAmount\": 10,\n  \"maxOrderAmount\": 10000,\n  \"serviceTypeRates\": {\n    \"cleaning\": {\n      \"platformRate\": 0.10,\n      \"executorRate\": 0.85\n    },\n    \"maintenance\": {\n      \"platformRate\": 0.12,\n      \"executorRate\": 0.82\n    }\n  },\n  \"tieredRates\": [\n    {\"minOrders\": 0, \"maxOrders\": 10, \"executorRateBonus\": 0},\n    {\"minOrders\": 11, \"maxOrders\": 30, \"executorRateBonus\": 0.02},\n    {\"minOrders\": 31, \"maxOrders\": 50, \"executorRateBonus\": 0.03},\n    {\"minOrders\": 51, \"maxOrders\": null, \"executorRateBonus\": 0.05}\n  ],\n  \"withdrawMinAmount\": 100,\n  \"withdrawFee\": 0,\n  \"withdrawTaxRate\": 0\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/profit-sharing",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "profit-sharing"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
